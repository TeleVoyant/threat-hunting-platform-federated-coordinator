# Copy to .env (compose reads it). REAL secrets do NOT belong here — the JWT
# secret is mounted as a Docker secret file (./secrets/fl_jwt_secret), never env.

# Hostname the coordinator's TLS server cert is issued for (used by init_ca).
FL_HOSTNAME=fl.example.com

# Reject contributions larger than this many bytes (DoS guard).
FL_MAX_MODEL_BYTES=67108864

# Path (inside the container) to the public/synthetic validation set used for
# trust + poisoning scoring. Leave unset for structure-only trust.
FL_VALIDATION_DATA=/app/config/validation.svm

# Require verified mTLS for org endpoints (challenge/contribute/global-model/
# announcement). When set, the X-FL-API-Key bootstrap fallback is refused —
# recommended in production behind `uvicorn --ssl-cert-reqs 2`.
FL_REQUIRE_MTLS=1

# Upper bound on a contribution's self-reported num_examples when it is turned
# into aggregation weight (trust x num_examples). Caps how much a single org
# can inflate its share of the merged ensemble. Default 1000000.
FL_MAX_NUM_EXAMPLES=1000000

# Observation window (hours) applied to BOTH the round intake window (contributions
# are collected/observed before aggregation is allowed) and the staged global-model
# soak (a merged model is observed before it can be published). Operator triggers
# aggregate + publish after each window elapses. Default 48. Set 0 for no wait
# (demos/tests). Per-round override: StartRoundRequest.observation_hours.
FL_OBSERVATION_HOURS=48
